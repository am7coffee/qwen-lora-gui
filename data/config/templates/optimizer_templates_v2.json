    "AdamW8bit": {
      "display_name": "AdamW8bit (メモリ効率)",
      "command_value": "bitsandbytes.optim.AdamW8bit",
      "description": "8ビット量子化による省メモリ版AdamW。大規模モデルの学習に適しています。迷ったらとりあえずこれ。",
      "category": "quantized",
      "arguments": [
        {
          "name": "betas",
          "display_name": "モーメンタム係数",
          "type": "string",
          "default": "(0.9, 0.999)",
          "required": false,
          "description": "1次と2次のモーメント推定の指数減衰率（例: 0.9, 0.999）",
          "ui_component": "text_input",
          "placeholder": "(0.9, 0.999)"
        },
        {
          "name": "eps",
          "display_name": "イプシロン",
          "type": "string",
          "default": "1e-8",
          "required": false,
          "description": "数値安定性のための小さな定数",
          "ui_component": "text_input",
          "placeholder": "1e-8"
        },
        {
          "name": "weight_decay",
          "display_name": "Weight Decay",
          "type": "float",
          "default": 0.01,
          "min": 0.0,
          "max": 1.0,
          "required": false,
          "description": "L2正則化の強度",
          "ui_component": "number_input",
          "step": 0.001,
          "precision": 4
        },
        {
          "name": "amsgrad",
          "display_name": "AMSGrad",
          "type": "choice",
          "choices": ["True", "False"],
          "default": "False",
          "required": false,
          "description": "AMSGradアルゴリズムを使用",
          "ui_component": "dropdown"
        },
        {
          "name": "optim_bits",
          "display_name": "量子化ビット数",
          "type": "choice",
          "choices": ["6", "8", "32"],
          "default": "6",
          "required": false,
          "description": "オプティマイザー状態の量子化ビット数",
          "ui_component": "dropdown"
        }
      ]
    },
